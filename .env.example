# ============================================================
# VN Fashion Shop - Environment Variables
# Copy this file to .env and fill in the values
#
#   cp .env.example .env
#
# For local development WITHOUT Docker, change DB_HOST=localhost
# and REDIS_HOST=localhost.
# ============================================================

# ---------- Database ----------
# For Docker Compose: DB_HOST=db
# For local dev (no Docker): DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vnfashion

# ---------- Redis ----------
# For Docker Compose: REDIS_HOST=redis
# For local dev (no Docker): REDIS_HOST=localhost
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- JWT / Auth ----------
# Change these to strong random values in production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- App ----------
# Change SECRET_KEY in production
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true

# ---------- Stripe Payments ----------
# Get your keys from https://dashboard.stripe.com/apikeys
# The placeholder values below will load the app but payment flows won't work.
# For testing, use Stripe test keys (sk_test_... / pk_test_...)
STRIPE_SECRET_KEY=sk_test_placeholder_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_placeholder_replace_with_real_secret
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_replace_with_real_key

# ---------- OAuth: Google (optional) ----------
# Leave empty to disable Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- AWS / S3 (optional) ----------
# Leave empty to disable S3 image uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vnfashion-media
AWS_S3_REGION=ap-southeast-1

# ---------- Email / SMTP (optional) ----------
# Leave empty to disable email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---------- Frontend (Next.js) ----------
# For local dev: http://localhost:8000/api/v1
# For Docker Compose: /api/v1 (proxied via Next.js rewrites)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STRIPE_KEY=pk_test_placeholder_replace_with_real_key
